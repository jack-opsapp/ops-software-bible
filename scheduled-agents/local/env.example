# Copy this to ~/.config/ops-nightly/env and fill in your values.
# chmod 600 the destination file:
#   mkdir -p ~/.config/ops-nightly
#   cp env.example ~/.config/ops-nightly/env
#   chmod 600 ~/.config/ops-nightly/env
#   $EDITOR ~/.config/ops-nightly/env

# Required — bearer token for https://app.opsapp.co/api/cron/bug-triage/*
export BUG_TRIAGE_AGENT_TOKEN="paste-the-64-char-hex-token-here"

# Optional — only if you want the nightly run to use a specific Anthropic API
# key instead of your local `claude` CLI's existing OAuth login. Leave unset to
# use whatever auth `claude` already has.
# export ANTHROPIC_API_KEY="sk-ant-..."
